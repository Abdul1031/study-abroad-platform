# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string. For local dev, run `docker compose up -d db`
# or point at a local Postgres instance. For deployment, use a managed
# Postgres URL (Neon, Supabase, Render, etc.) — see DEPLOYMENT.md.
DATABASE_URL="postgresql://user:password@localhost:5432/study_abroad?schema=public"

# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Auth (Refresh Token Rotation) ────────────────────────────────────────
# REQUIRED in production — the server refuses to boot without a secret of at
# least 32 characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-64-character-hex-string-before-deploying

# Comma-separated emails granted the ADMIN role (data-quality dashboard,
# scraper controls). Leave empty in dev to test as a regular student.
ADMIN_EMAILS=

# ── CORS ──────────────────────────────────────────────────────────────────
# Origin of the deployed frontend (no trailing slash).
FRONTEND_URL=http://localhost:3000
# Optional extra allowed origins, comma-separated (e.g. preview deployments).
CORS_ALLOWED_ORIGINS=

# ── Scraper ───────────────────────────────────────────────────────────────
SCRAPER_ENABLED=true
SCRAPER_TIMEOUT_MS=15000
SCRAPER_RATE_LIMIT_MS=2000
SCRAPER_MAX_RETRIES=3
SCRAPER_MAX_CONCURRENT=5
